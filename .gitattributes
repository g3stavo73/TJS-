# Auto detect text files and normalize line endings to LF
* text=auto

# Batch files
*.bat text eol=crlf
*.cmd text eol=crlf
*.exe binary

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Web
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
